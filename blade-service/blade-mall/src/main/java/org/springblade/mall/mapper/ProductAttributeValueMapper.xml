<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.springblade.mall.mapper.ProductAttributeValueMapper">

    <!-- 物理删除商品属性值（绕过@TableLogic限制） -->
    <delete id="deletePhysicalByProductId">
        DELETE FROM mall_product_attribute_value WHERE product_id = #{productId}
    </delete>

</mapper>

